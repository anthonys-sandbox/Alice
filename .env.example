# === GravityClaw Configuration ===

# Gemini API Key (required) - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional, defaults to gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# OpenRouter API Key (optional) - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Google Chat via Apps Script Relay (see scripts/apps-script-relay.js for setup)
APPS_SCRIPT_RELAY_URL=
RELAY_SECRET=

# Gateway server port (optional, defaults to 18790)
GATEWAY_PORT=18790

# Heartbeat interval in minutes (optional, defaults to 30)
HEARTBEAT_INTERVAL=30

# Log level (optional: debug, info, warn, error)
LOG_LEVEL=info
