# === Alice Configuration ===

# Chat provider: 'ollama' (default, local & free) or 'gemini'
CHAT_PROVIDER=ollama

# Gemini API Key (required for image gen + Gemini chat provider)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional, defaults to gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# Ollama local model config (used when CHAT_PROVIDER=ollama)
# qwen3:8b = fast, great instruction following + tool calling
# qwen3-vl = vision model, used automatically when images are attached
OLLAMA_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen3-vl
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# Google Chat Integration (optional — see README for setup)
RELAY_SHEET_ID=your_google_sheet_id_here
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_SA_KEY_PATH=./alice-chat-sa.json

# Gateway server port (optional, defaults to 18790)
GATEWAY_PORT=18790

# Heartbeat interval in minutes (optional, defaults to 30)
HEARTBEAT_INTERVAL=30

# Log level (optional: debug, info, warn, error)
LOG_LEVEL=info
