# === Alice Configuration ===

# Chat provider: 'gemini' (default) or 'ollama' (local & free)
CHAT_PROVIDER=gemini

# Gemini API Key (required for image gen + Gemini chat provider)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional, defaults to gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# Gemini Auth Mode (optional, defaults to 'apikey')
# 'apikey' — uses GEMINI_API_KEY with generous rate limits (recommended)
# 'cli'    — uses Gemini CLI OAuth (free via Ultra subscription, but stricter rate limits)
# 'auto'   — auto-detects CLI credentials, falls back to API key
GEMINI_AUTH=apikey

# Background model — lightweight local model for non-user-facing tasks
# (memory extraction, auto-title, heartbeat, consolidation)
# Runs on Ollama. Falls back to primary model if Ollama is unavailable.
BACKGROUND_MODEL=llama3.1:8b

# Ollama local model config (used when CHAT_PROVIDER=ollama)
# llama3.1:8b = 4.9 GB model, Text + Tool calling
# One model handles everything
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llama3.1:8b
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434
# OLLAMA_FALLBACK_MODEL=llama3.1:8b

# Google Chat Integration (optional — see README for setup)
RELAY_SHEET_ID=your_google_sheet_id_here
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_SA_KEY_PATH=./alice-chat-sa.json

# Gateway server port (optional, defaults to 18790)
GATEWAY_PORT=18790

# Heartbeat interval in minutes (optional, defaults to 30)
HEARTBEAT_INTERVAL=30

# Log level (optional: debug, info, warn, error)
LOG_LEVEL=info

# OpenRouter API Key (optional — enables free cloud models)
# Get from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Personal Access Token (for GitHub MCP server)
# Get from https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# ChatGPT Enterprise (optional — uses Codex CLI OAuth, no API key needed)
# Requires: npx codex (log in once with your Enterprise account)
# CHAT_PROVIDER=chatgpt
