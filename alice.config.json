{
    "chatProvider": "gemini",
    "gemini": {
        "model": "gemini-3-flash-preview"
    },
    "ollama": {},
    "gateway": {
        "host": "0.0.0.0",
        "port": 18790
    },
    "heartbeat": {
        "enabled": true,
        "intervalMinutes": 360
    },
    "agent": {
        "maxIterations": 25,
        "timeoutMs": 300000
    },
    "logging": {
        "level": "info"
    },
    "mcp": {
        "servers": [
            {
                "name": "weather",
                "command": "npx",
                "args": [
                    "-y",
                    "open-meteo-mcp-lite"
                ]
            },
            {
                "name": "github",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-github"
                ],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
                }
            },
            {
                "name": "filesystem",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "/Users/AnthonyTackett/Documents"
                ]
            },
            {
                "name": "notebooklm",
                "command": "npx",
                "args": [
                    "-y",
                    "notebooklm-mcp"
                ],
                "enabled": true
            }
        ]
    }
}