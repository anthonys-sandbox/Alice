{
    "chatProvider": "gemini",
    "gemini": {
        "model": "gemini-3-flash-preview"
    },
    "ollama": {
        "model": "qwen3:8b",
        "visionModel": "qwen3-vl"
    },
    "gateway": {
        "host": "0.0.0.0",
        "port": 18790
    },
    "heartbeat": {
        "enabled": true,
        "intervalMinutes": 30
    },
    "agent": {
        "maxIterations": 25,
        "timeoutMs": 300000
    },
    "logging": {
        "level": "info"
    },
    "mcp": {
        "servers": [
            {
                "name": "weather",
                "command": "npx",
                "args": [
                    "-y",
                    "open-meteo-mcp-server"
                ]
            },
            {
                "name": "github",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-github"
                ],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
                }
            },
            {
                "name": "google-calendar",
                "command": "npx",
                "args": [
                    "-y",
                    "@cocal/google-calendar-mcp"
                ],
                "env": {
                    "GOOGLE_OAUTH_CREDENTIALS": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw/credentials.json"
                },
                "cwd": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw",
                "enabled": true
            },
            {
                "name": "gmail",
                "command": "npx",
                "args": [
                    "-y",
                    "@gongrzhe/server-gmail-autoauth-mcp"
                ],
                "env": {
                    "GMAIL_OAUTH_PATH": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw/credentials.json",
                    "GMAIL_CREDENTIALS_PATH": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw/gmail-tokens.json",
                    "CREDENTIALS_PATH": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw/gmail-tokens.json"
                },
                "cwd": "/Users/AnthonyTackett/Documents/GitHub/GravityClaw",
                "enabled": true
            },
            {
                "name": "filesystem",
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "/Users/AnthonyTackett/Documents"
                ]
            },
            {
                "name": "notebooklm",
                "command": "npx",
                "args": [
                    "-y",
                    "notebooklm-mcp"
                ],
                "enabled": true
            }
        ]
    }
}