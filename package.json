{
  "name": "alice",
  "version": "1.0.0",
  "description": "A self-hosted AI agent that runs locally on your Mac, communicates via Google Chat, and uses the Gemini API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "alice": "./dist/index.js"
  },
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=./system-ca.pem tsx watch src/index.ts",
    "start": "NODE_EXTRA_CA_CERTS=./system-ca.pem node dist/index.js",
    "build": "tsc",
    "chat": "NODE_EXTRA_CA_CERTS=./system-ca.pem tsx src/index.ts chat",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "gemini",
    "google-chat",
    "assistant"
  ],
  "author": "Anthony Tackett",
  "license": "MIT",
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.37.0",
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.41.0",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "open": "^11.0.0",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "puppeteer": "^24.37.5",
    "readline": "^1.3.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
